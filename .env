# Local development environment variables
# Replace the URL below with your Postgres connection string.
# For example: postgres://username:password@localhost:5432/your_db_name
DATABASE_URL=postgres://user:password@localhost:5432/mydb

# Host and port to bind the server to (use 127.0.0.1 if 0.0.0.0 fails)
HOST=127.0.0.1
PORT=5000
